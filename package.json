{
  "name": "@upassist/neos-mcp",
  "version": "2.0.1",
  "description": "MCP server for Neos CMS — connects AI assistants to any UpAssist.Neos.Mcp bridge",
  "license": "MIT",
  "bin": {
    "neos-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "node --import=tsx src/index.ts",
    "release:prerelease": "npx standard-version -t '' -r patch --prerelease && git push --follow-tags",
    "release:patch": "npx standard-version -t '' -r patch && git push --follow-tags",
    "release:minor": "npx standard-version -t '' -r minor && git push --follow-tags",
    "release:major": "npx standard-version -t '' -r major && git push --follow-tags",
    "release": "yarn release:patch"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
